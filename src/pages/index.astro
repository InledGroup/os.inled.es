---
// Landing Page for Pulsar OS (Aligned with Star Labs/Novacustom visual style)
// Página de Aterrizaje General de Pulsar OS (Alineada con el estilo visual de Star Labs/Novacustom)
import Layout from "../layouts/Layout.astro";
---

<Layout title="The True Replacement for Mac and Windows">
    <!-- Hero Section (2-column layout, pill buttons, large rounded image placeholder) -->
    <!-- Sección Hero (Layout de 2 columnas, botones píldora, marcador de imagen grande) -->
    <section id="hero" class="hero-section">
        <div class="container hero-grid">
            <!-- Left Column: Copy & Actions / Columna Izquierda: Texto y Acciones -->
            <div class="hero-left">
                <h1 class="hero-title">
                    The perfect replacement for Mac and Windows.
                </h1>
                <p class="hero-desc">
                    Linux based operative systems designed to replicate the
                    MacOS and Windows experience. Truly open-source and
                    community driven. Elegant, stable and auditable.
                    <!-- Un sistema operativo elegante, completamente auditable y comunitario diseñado para clonar el flujo de tu entorno preferido con cero telemetría y libertad total. -->
                </p>
                <div class="hero-actions">
                    <a
                        href="https://github.com/Inled-Pulsar-OS"
                        class="btn btn-primary"
                    >
                        View on Github
                        <svg
                            class="btn-arrow"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </a>
                    <a
                        href="https://github.com/orgs/Inled-Pulsar-OS/projects/1"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn btn-secondary"
                    >
                        Explore Project Roadmap
                    </a>
                    <a
                        href="https://discord.com/invite/PSeTkDMnr"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn btn-secondary"
                    >
                        <i class="fa-brands fa-discord"></i> Discord
                    </a>
                    <a
                        href="https://matrix.to/#/!POXBFohLnmrKwRBxTi:matrix.org?via=matrix.org"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn btn-secondary"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 512 512"
                            width="16"
                            height="16"
                            style="vertical-align: middle; margin-right: 6px;"
                        >
                            <path
                                fill="currentColor"
                                d="M61.6 27l-32.9 0 0 458 32.9 0 0 11-45.6 0 0-480 45.6 0 0 11zM496 496l-45.6 0 0-11 32.9 0 0-458-32.9 0 0-11 45.6 0 0 480zM324.1 167.6c9 0 17.4 1.1 25.2 3.3s14.3 5.7 19.8 10.6 9.8 11.2 12.9 19c3 7.8 4.6 17.3 4.6 28.3l0 114.5-47 0 0-97c0-5.7-.2-11.2-.6-16.3s-1.7-9.5-3.6-13.2c-2-3.8-4.9-6.8-8.7-9s-9.1-3.3-15.7-3.3c-6.6 0-12 1.3-16.1 3.8-4.1 2.6-7.3 5.8-9.6 10-2.3 4.1-3.9 8.7-4.6 13.9-.7 5.2-1.2 10.4-1.2 15.7l0 95.3-47 0 0-96c0-5.1-.1-10.1-.4-15-.2-5-1.2-9.5-2.9-13.8-1.7-4.1-4.4-7.6-8.3-10.1s-9.5-3.8-17.1-3.8c-2.2 0-5.2 .5-8.8 1.5s-7.2 2.9-10.6 5.6-6.4 6.7-8.8 11.9-3.6 12-3.6 20.4l0 99.3-47 0 0-171.3 44.3 0 0 23.2 .7 0c6.2-8.9 13.7-15.7 22.3-20.5 8.7-4.9 18.7-7.3 30-7.3 10.8 0 20.7 2.1 29.6 6.3s15.7 11.6 20.4 22.2c5.1-7.5 12-14.1 20.7-19.8s19-8.6 30.9-8.6z"
                            ></path>
                        </svg>
                        Matrix
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Hero Features Row (4 clean cards in a horizontal row on desktop, inspired by reference image) -->
    <!-- Fila de Características del Hero (4 tarjetas limpias en una fila horizontal en escritorio, inspiradas en la referencia) -->
    <section class="hero-features-section">
        <div class="container hero-features-grid">
            <!-- Feature Card 1 -->
            <div class="feature-card">
                <h3 class="feature-title">
                    Macos, Windows and Android integration
                </h3>
                <p class="feature-desc">
                    With Pulsar, you can use the apps of your Android phone as
                    desktop apps, you can run a fully MacOS desktop from
                    official servers and execute Windows apps as native apps
                    WITHOUT WINE, WITH REAL WINDOWS.
                    <!-- Diseñado sobre bases de Linux modernas, no adaptado a posteriori. Estable, seguro y listo para el día a día. -->
                </p>
            </div>

            <!-- Feature Card 2 -->
            <div class="feature-card">
                <h3 class="feature-title">100% Usable</h3>
                <p class="feature-desc">
                    Unlike other distributions that try to replicate the look
                    and feel, Pulsar OS is 100% functional in both of its
                    flavors. You'll have the same experience as in a normal
                    Linux environment.
                    <!-- Un entorno de escritorio completamente funcional y estable configurado de fábrica para trabajar y jugar. -->
                </p>
            </div>

            <!-- Feature Card 3 -->
            <div class="feature-card">
                <h3 class="feature-title">Rock-solid base</h3>
                <p class="feature-desc">
                    Unlike other customized distributions, we are not based on
                    Ubuntu or Arch. Pulsar OS is based on the mother of them
                    all: Debian.
                    <!-- Construido usando los repositorios de Debian Trixie. Misma estabilidad y paquetes del sistema core. -->
                </p>
            </div>

            <!-- Feature Card 4 -->
            <div class="feature-card">
                <h3 class="feature-title">Fully Auditable</h3>
                <p class="feature-desc">
                    Everything is built on GitHub Actions, whose workflow and
                    source code are auditable. We are the first Linux
                    distribution that is 100% replicable from source code.
                    <!-- Sin telemetría oculta ni restricciones de licencia. Verifica el código, audita y compila componentes. -->
                </p>
            </div>
        </div>
    </section>

    <!-- Flavours Section (Clean description cards, no feature lists, clean image placeholders) -->
    <!-- Sección de Sabores (Tarjetas descriptivas limpias, sin listas de características, marcadores de imagen) -->
    <section id="flavours" class="flavours-section">
        <div class="container">
            <h2 class="section-title">Designed for Your Workflow</h2>
            <p class="section-subtitle">
                Pulsar OS is distributed in two target desktop configurations
                tailored to mimic macOS and Windows.
                <!-- Pulsar OS se ofrece en dos configuraciones de escritorio adaptadas para imitar macOS y Windows. -->
            </p>

            <!-- Pear Flavour -->
            <div class="flavour-row">
                <div class="flavour-info">
                    <h3 class="flavour-title">Tahoe</h3>
                    <p class="flavour-desc">
                        It perfectly replicates the aesthetics of MacOS, even
                        improving usability.
                        <!-- Replica la estética pulida, barra superior, dock de aplicaciones y flujo Unix de macOS. Perfecto para la elegancia visual y desarrollo. -->
                    </p>
                </div>
                <div class="flavour-media">
                    <div class="image-placeholder">
                        <img src="demopear1.png" />
                    </div>
                </div>
            </div>

            <!-- Wintux Flavour (Inverted Row) -->
            <div class="flavour-row inverted">
                <div class="flavour-info">
                    <h3 class="flavour-title">Wintux</h3>
                    <p class="flavour-desc">
                        Forget it, you don't need Winux or Ubuntu, you need
                        something auditable and just like the Windows you love.
                        <!-- Conserva el menú de inicio centrado, barra de tareas y atajos de teclado estándar de Windows. El puente de migración ideal. -->
                    </p>
                </div>
                <div class="flavour-media">
                    <div class="image-placeholder">
                        <img
                            src="https://hosted.inled.es/pulsar-win11-nobg.png"
                            class="image-placeholder-icon"
                        />
                        <div class="image-placeholder-title">Coming soon</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Release Channels Section (Stable, Forky, Rolling) -->
    <section id="releases" class="releases-section">
        <div class="container">
            <h2 class="section-title">Three release channels for each flavour</h2>
            <p class="section-subtitle">
                Every Pulsar OS flavour is available in three tracks so you can
                choose the stability level that fits your needs.
            </p>
            <div class="releases-grid">
                <div class="release-card">
                    <div class="release-badge stable">Stable</div>
                    <h3 class="release-title">Trixie</h3>
                    <p class="release-desc">
                        Based on the current Debian stable release (13 Trixie).
                        The most tested and reliable version, recommended for
                        production, daily use, and medium-range PCs.
                    </p>
                </div>
                <div class="release-card">
                    <div class="release-badge forky">Forky</div>
                    <h3 class="release-title">Forky</h3>
                    <p class="release-desc">
                        Based on Debian testing. When the next Debian stable
                        arrives, Forky stops being rolling and becomes the new
                        stable. Ideal for users who want fresher software
                        without full bleeding edge.
                    </p>
                </div>
                <div class="release-card">
                    <div class="release-badge rolling">Rolling</div>
                    <h3 class="release-title">Rolling Release</h3>
                    <p class="release-desc">
                        Continuously updated from Debian testing. Always ships
                        the latest packages and kernels. Designed for
                        enthusiasts and advanced users who want cutting-edge
                        software.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Pulsar Integrations Section (Macboat, Winboat, Droidtux) -->
    <!-- Sección de Integraciones de Pulsar (Macboat, Winboat, Droidtux) -->
    <section id="integrations" class="integrations-section">
        <div class="container">
            <h2 class="section-title">Seamless Integrations</h2>
            <p class="section-subtitle">
                Access your other environments directly from Pulsar OS with
                native system integrations.
                <!-- Accede a tus otros entornos directamente desde Pulsar OS con integraciones nativas de sistema. -->
            </p>

            <div class="integrations-grid">
                <!-- Macboat Integration -->
                <div class="integration-card">
                    <img
                        src="https://hosted.inled.es/macboat.png"
                        alt="Macboat Logo"
                        class="integration-logo"
                    />
                    <h3 class="integration-title">Macboat</h3>
                    <p class="integration-desc">
                        Run a fully featured macOS desktop environment directly
                        from official servers. Enjoy perfect Visual alignment
                        and software compatibility.
                        <!-- Ejecuta un escritorio macOS completo desde servidores oficiales. Compatibilidad visual y de software perfecta. -->
                    </p>
                </div>

                <!-- Winboat Integration -->
                <div class="integration-card">
                    <img
                        src="https://hosted.inled.es/winboat_logo.NqN8dmd9.svg"
                        alt="Winboat Logo"
                        class="integration-logo"
                    />
                    <span class="integration-meta">Third Party</span>
                    <h3 class="integration-title">Winboat</h3>
                    <p class="integration-desc">
                        Execute native Windows applications directly on Pulsar
                        OS. Runs on top of a real Windows instance for absolute
                        compatibility without WINE bottlenecks.
                        <!-- Ejecuta aplicaciones nativas de Windows directamente en Pulsar OS sobre una instancia de Windows real sin cuellos de botella de WINE. -->
                    </p>
                </div>

                <!-- Droidtux Integration -->
                <div class="integration-card">
                    <img
                        src="https://hosted.inled.es/droidtux.png"
                        alt="Droidtux Logo"
                        class="integration-logo"
                    />
                    <h3 class="integration-title">Droidtux</h3>
                    <p class="integration-desc">
                        Run the applications of your Android phone as floating
                        desktop windows. The apps remain executed on your phone
                        rather than your PC, ensuring maximum portability.
                        <!-- Ejecuta aplicaciones de tu teléfono Android en ventanas de escritorio. Las apps se ejecutan en tu teléfono para mayor portabilidad. -->
                    </p>
                </div>

                <!-- GSConnect Integration -->
                <div class="integration-card">
                    <img
                        src="https://hosted.inled.es/gsconnect.png"
                        alt="GSConnect Logo"
                        class="integration-logo"
                    />
                    <h3 class="integration-title">GSConnect</h3>
                    <p class="integration-desc">
                        Seamlessly integrate your Android phone with Pulsar OS.
                        Receive notifications, send and receive messages, share
                        files, and control your phone from your desktop.
                        <!-- Integra tu teléfono Android con Pulsar OS. Notificaciones, mensajes, archivos y control desde el escritorio. -->
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Enterprise, Individual & Institution Section -->
    <!-- Sección para Empresas, Particulares e Instituciones -->
    <section id="enterprise" class="enterprise-section">
        <div class="container">
            <h2 class="section-title">
                Perfect for companies, individuals and institutions
            </h2>
            <p class="section-subtitle">
                Pulsar OS is designed to fit any environment — professional,
                personal or institutional. Transparency, sovereignty and
                familiarity in a single system.
            </p>

            <div class="enterprise-features-grid">
                <div class="enterprise-card">
                    <h3 class="enterprise-card-title">100% auditable code</h3>
                    <p class="enterprise-card-desc">
                        One of the few distributions with fully auditable source
                        code. Everything is built on GitHub Actions and every
                        line can be verified.
                    </p>
                </div>

                <div class="enterprise-card">
                    <h3 class="enterprise-card-title">
                        Sovereign and European
                    </h3>
                    <p class="enterprise-card-desc">
                        Developed entirely in Europe, with no dependency on
                        foreign big-tech technologies or services. Real digital
                        sovereignty.
                    </p>
                </div>

                <div class="enterprise-card">
                    <h3 class="enterprise-card-title">Community-driven</h3>
                    <p class="enterprise-card-desc">
                        Built by and for the community. Decisions are made
                        openly and transparently, with no hidden corporate
                        interests.
                    </p>
                </div>

                <div class="enterprise-card">
                    <h3 class="enterprise-card-title">Familiar for everyone</h3>
                    <p class="enterprise-card-desc">
                        Perfectly replicates the designs of mainstream operating
                        systems. Both individual users and company employees
                        will feel right at home.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Current State Notice -->
    <section class="notice-section">
        <div class="container notice-container">
            <div class="notice-card">
                <span class="notice-icon">&#9432;</span>
                <div class="notice-content">
                    <h3 class="notice-title">Current state</h3>
                    <p class="notice-desc">
                        We are moving from being users who develop GNOME
                        extensions and apps to building a full distribution.
                        This is new territory, and we welcome feedback on any
                        bumps along the road.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Community & Contribute Section -->
    <!-- Sección de Comunidad y Contribución -->
    <section id="community" class="community-section">
        <div class="container community-container">
            <div class="community-card">
                <h2 class="community-title">Community</h2>
                <p class="community-desc">
                    We want to grow by delegating responsibility, not by
                    concentrating decisions in a handful of people. If you want
                    to become a contributor, get in touch.
                </p>
                <div class="community-actions">
                    <a
                        href="https://discord.com/invite/PSeTkDMnr"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn btn-secondary"
                    >
                        <i class="fa-brands fa-discord"></i> Discord
                    </a>
                    <a
                        href="https://matrix.to/#/!POXBFohLnmrKwRBxTi:matrix.org?via=matrix.org"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn btn-secondary"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 512 512"
                            width="16"
                            height="16"
                            style="vertical-align: middle; margin-right: 6px;"
                        >
                            <path
                                fill="currentColor"
                                d="M61.6 27l-32.9 0 0 458 32.9 0 0 11-45.6 0 0-480 45.6 0 0 11zM496 496l-45.6 0 0-11 32.9 0 0-458-32.9 0 0-11 45.6 0 0 480zM324.1 167.6c9 0 17.4 1.1 25.2 3.3s14.3 5.7 19.8 10.6 9.8 11.2 12.9 19c3 7.8 4.6 17.3 4.6 28.3l0 114.5-47 0 0-97c0-5.7-.2-11.2-.6-16.3s-1.7-9.5-3.6-13.2c-2-3.8-4.9-6.8-8.7-9s-9.1-3.3-15.7-3.3c-6.6 0-12 1.3-16.1 3.8-4.1 2.6-7.3 5.8-9.6 10-2.3 4.1-3.9 8.7-4.6 13.9-.7 5.2-1.2 10.4-1.2 15.7l0 95.3-47 0 0-96c0-5.1-.1-10.1-.4-15-.2-5-1.2-9.5-2.9-13.8-1.7-4.1-4.4-7.6-8.3-10.1s-9.5-3.8-17.1-3.8c-2.2 0-5.2 .5-8.8 1.5s-7.2 2.9-10.6 5.6-6.4 6.7-8.8 11.9-3.6 12-3.6 20.4l0 99.3-47 0 0-171.3 44.3 0 0 23.2 .7 0c6.2-8.9 13.7-15.7 22.3-20.5 8.7-4.9 18.7-7.3 30-7.3 10.8 0 20.7 2.1 29.6 6.3s15.7 11.6 20.4 22.2c5.1-7.5 12-14.1 20.7-19.8s19-8.6 30.9-8.6z"
                            ></path>
                        </svg>
                        Matrix
                    </a>
                    <a
                        href="https://github.com/Inled-Pulsar-OS/DOCS/wiki"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn btn-secondary"
                    >
                        Documentation
                    </a>
                    <a href="/contribute" class="btn btn-secondary">
                        See how to contribute
                    </a>
                </div>
            </div>
        </div>
    </section>
</Layout>
