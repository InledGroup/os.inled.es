---
// Base Layout for Pulsar OS Web (Landing Only)
// Layout Base para la Web de Pulsar OS (Solo Landing)
import "../styles/global.css";

interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "Pulsar OS is a community-driven, 100% auditable operating system designed to replicate macOS (Pear) and Windows (Wintux) workflows.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />

        <!-- Favicon using remote logo link / Favicon usando enlace de logo remoto -->
        <link
            rel="icon"
            type="image/svg+xml"
            href="https://hosted.inled.es/pulsar-logo-simple-sf.png"
        />

        <title>{title} — Pulsar OS</title>

        <!-- Google Fonts: Space Grotesk and Inter / Fuentes de Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />

        <!-- Theme prevention script: defaults to light (warm cream) / Script de prevención de tema: por defecto claro (crema cálido) -->
        <script is:inline>
            // Run immediately before DOM rendering / Ejecutar inmediatamente antes de que el DOM se renderice
            (function () {
                const savedTheme = localStorage.getItem("theme");
                const prefersDark = window.matchMedia(
                    "(prefers-color-scheme: dark)",
                ).matches;
                if (savedTheme === "dark" || (!savedTheme && prefersDark)) {
                    document.documentElement.classList.add("dark");
                } else {
                    document.documentElement.classList.remove("dark");
                }
            })();
        </script>
    </head>
    <body>
        <!-- Floating Header / Cabecera Flotante (Inspired by Star Labs navigation layout) -->
        <header class="floating-header">
            <div class="container header-container">
                <a href="/" class="logo-container">
                    <!-- Logo points to the remote URL as requested / El logo apunta a la URL remota requerida -->
                    <img
                        src="https://hosted.inled.es/pulsar-logo-simple-sf.png"
                        alt="Pulsar OS Logo"
                        class="logo-img"
                    />
                    <span class="logo-text">Pulsar OS</span>
                </a>

                <nav class="nav-links">
                    <a href="#hero" class="nav-link">Home</a>
                    <a href="#flavours" class="nav-link">Flavours</a>
                    <a href="#features" class="nav-link">Features</a>
                    <a href="#status" class="nav-link">Project Status</a>
                    <a href="#community" class="nav-link">Community</a>
                </nav>

                <div class="header-actions">
                    <!-- Theme Toggle Button / Botón de cambio de tema -->
                    <button
                        id="theme-toggle"
                        class="theme-toggle-btn"
                        aria-label="Toggle light or dark theme"
                    >
                        <!-- Sun Icon (shown in dark mode) / Icono de Sol (se muestra en modo oscuro) -->
                        <svg
                            class="sun-icon"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <circle cx="12" cy="12" r="5"></circle>
                            <line x1="12" y1="1" x2="12" y2="3"></line>
                            <line x1="12" y1="21" x2="12" y2="23"></line>
                            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"
                            ></line>
                            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"
                            ></line>
                            <line x1="1" y1="12" x2="3" y2="12"></line>
                            <line x1="21" y1="12" x2="23" y2="12"></line>
                            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"
                            ></line>
                            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"
                            ></line>
                        </svg>
                        <!-- Moon Icon (shown in light mode) / Icono de Luna (se muestra en modo claro) -->
                        <svg
                            class="moon-icon"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path
                                d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
                            ></path>
                        </svg>
                    </button>

                    <a
                        href="#community"
                        class="btn btn-primary btn-nav-download"
                        >Download (coming soon)</a
                    >
                </div>
            </div>
        </header>

        <!-- Page Content Slot / Contenedor principal de contenido -->
        <main class="main-content">
            <slot />
        </main>

        <!-- Footer / Pie de Página -->
        <footer class="site-footer">
            <div class="container footer-container">
                <div class="footer-left">
                    <a href="/" class="footer-logo">
                        <img
                            src="https://hosted.inled.es/pulsar-logo-simple-sf.png"
                            alt="Pulsar OS Logo"
                            class="logo-img-small"
                        />
                        <span>Pulsar OS</span>
                    </a>
                    <p class="footer-copy">
                        Pulsar OS is made by <a href="https://inled.es"
                            >Inled Group</a
                        >, founded by <a href="https://jaimegh.com">JaimeGH</a>
                    </p>
                </div>
                <div class="footer-right">
                    <a
                        href="https://github.com/Inled-Pulsar-OS"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="footer-link">GitHub</a
                    >
                    <div></div>
                    <a
                        href="https://github.com/orgs/Inled-Pulsar-OS/projects/1"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="footer-link">Projects</a
                    >
                </div>
            </div>
        </footer>

        <!-- Theme handler logic / Lógica de control de temas -->
        <script>
            const themeToggle = document.getElementById("theme-toggle");

            themeToggle?.addEventListener("click", () => {
                const isDark =
                    document.documentElement.classList.toggle("dark");
                localStorage.setItem("theme", isDark ? "dark" : "light");
            });
        </script>
    </body>
</html>

<style>
    /* Header styling / Estilos de cabecera */

    .floating-header {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: calc(100% - 40px);
        max-width: var(--max-width);
        height: 70px;
        background: rgba(246, 244, 238, 0.75); /* Warm light blur */
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        z-index: 100;
        transition: all var(--transition-speed) ease;
    }

    html.dark .floating-header {
        background: rgba(13, 11, 21, 0.75); /* Dark theme blur */
    }

    .floating-header:hover {
        border-color: var(--border-focus);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }

    html.dark .floating-header:hover {
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
    }

    .header-container {
        height: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 24px;
    }

    .logo-container {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .logo-img {
        height: 36px;
        width: auto;
    }

    .logo-text {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.25rem;
        letter-spacing: -0.5px;
        color: var(--text-primary);
    }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 32px;
    }

    .nav-link {
        font-family: var(--font-body);
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--text-secondary);
        transition: color var(--transition-speed) ease;
    }

    .nav-link:hover {
        color: var(--text-primary);
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    /* Theme toggle styling / Estilos de botón de tema */
    .theme-toggle-btn {
        background: transparent;
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all var(--transition-speed) ease;
    }

    .theme-toggle-btn:hover {
        background: var(--bg-card-hover);
        border-color: var(--border-focus);
    }

    /* Sun/moon icon visibility rules based on .dark class on html */
    .sun-icon {
        display: none;
    }

    .moon-icon {
        display: block;
    }

    html.dark .sun-icon {
        display: block;
    }

    html.dark .moon-icon {
        display: none;
    }

    .btn-nav-download {
        padding: 10px 22px;
        font-size: 0.85rem;
    }

    /* Content area margins for floating header / Márgenes del contenido para cabecera flotante */
    .main-content {
        min-height: 80vh;
        padding-top: 120px;
    }

    /* Footer styles / Estilos del pie de página */
    .site-footer {
        border-top: 1px solid var(--border-color);
        padding: 40px 0;
        margin-top: 80px;
        background-color: rgba(233, 230, 220, 0.2);
    }

    html.dark .site-footer {
        background-color: rgba(23, 20, 36, 0.2);
    }

    .footer-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
    }

    .footer-left {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .footer-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        font-family: var(--font-display);
        font-weight: 700;
        color: var(--text-primary);
        font-size: 1.1rem;
    }

    .logo-img-small {
        height: 24px;
        width: auto;
    }

    .footer-copy {
        color: var(--text-secondary);
        font-size: 0.85rem;
    }

    .footer-links {
        display: flex;
        gap: 24px;
    }

    .footer-link {
        color: var(--text-secondary);
        font-size: 0.9rem;
        transition: color var(--transition-speed) ease;
    }

    .footer-link:hover {
        color: var(--text-primary);
    }

    /* Responsive styling / Estilos responsivos */
    @media (max-width: 800px) {
        .nav-links {
            display: none;
        }

        .footer-container {
            flex-direction: column;
            text-align: center;
            align-items: center;
        }

        .footer-left {
            align-items: center;
        }
    }
</style>
